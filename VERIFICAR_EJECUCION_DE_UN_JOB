SET LINESIZE 600
COL OWNER FORMAT A5
COL JOB_NAME FORMAT A30
COL NEXT_RUN_DATE FORMAT A35
COL STATE FORMAT A35
select OWNER
, JOB_NAME
, NEXT_RUN_DATE
, sysdate
, RUN_COUNT
, FAILURE_COUNT
, STATE
from DBA_SCHEDULER_JOBS
WHERE OWNER = 'SYS'
AND ENABLED = 'TRUE'
