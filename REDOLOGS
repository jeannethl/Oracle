-- REDOLOGS --
--------------
SET LINESIZE 600
COL MEMBER FORMAT A60
SELECT GROUP# "GROUP", STATUS, MEMBER
       , TYPE
       ,IS_RECOVERY_DEST_FILE 
FROM SYS.V$LOGFILE
--WHERE GROUP# IN (1,2,3,4,5,6)
--AND TYPE <> 'STANDBY'
ORDER BY 1, 2;

