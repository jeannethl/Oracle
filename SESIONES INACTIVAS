SESIONES INACTIVAS

set line 999 pages 300
CLEAR COLUMNS
CLEAR BREAKS
BREAK ON REPORT ON USERNAME SKIP 1
COMPUTE SUM LABEL TOTAL_SESSIONS_INACTIVES OF CANT_SESSIONS ON REPORT
col CANT_SESSIONS for 999,999,999
col USERNAME for a15
col LOGON_TIME format a40
COL PROGRAM FORMAT A30
col MACHINE format a60
col OSUSER FORMAT A20
col SPID FORMAT A10
select s.USERNAME USERNAME
, s.INST_ID
, s.MACHINE
, s.PROGRAM
, s.STATUS
, s.OSUSER
, p.SPID
, TO_CHAR(s.LOGON_TIME,'DD-MM-RRRR HH24:MI:SS') AS "LOGON_TIME"
, COUNT(1) CANT_SESSIONS
FROM GV$SESSION s
JOIN GV$PROCESS p ON p.ADDR = s.PADDR
AND s.STATUS!='ACTIVE'
AND s.USERNAME !='SYS'
--AND s.INST_ID = 3
-- AND S.USERNAME='OSBTT2_OSB_INFRA'
group by s.MACHINE, s.USERNAME, s.PROGRAM, s.STATUS, s.OSUSER, p.SPID
, s.INST_ID
,"LOGON_TIME"
order by  7 desc
/