COLUMN name FORMAT a25
COLUMN path FORMAT a25
COLUMN diskgroup_name FORMAT a20
SELECT a.group_number, b.name, a.path, a.name, a.header_status, a.state, a.total_mb, a.free_mb,a.REDUNDANCY
FROM v$asm_disk a, v$asm_diskgroup b
WHERE a.group_number = b.group_number
AND b.name like '%DATA'
--AND b.name = 'FRA'
ORDER BY a.name, a.group_number;






