#-- Indice --#
1.- Validar estatus de los indexes
2.- Validar size de los indexes
3.- Validar espacio disponible en tablespace destino
4.- Ejecutar Pl/Sql


#-- Pasos --#


NOTA: Los pasos presentados estan certificados para oracle 11g


1.- Validar estatus de los indexes
----------------------------------


SELECT OWNER
, INDEX_NAME
, STATUS
, TABLE_NAME
, TABLESPACE_NAME
FROM dba_indexes
where OWNER='MPOS'
AND TABLESPACE_NAME = 'USERS'
/



2.- Validar size de los indexes
-------------------------------


2.1.- Size all indexes



select owner
,segment_name
,sum(bytes)/1024/1024 as "SIZE in MB"
from dba_segments
where owner='MPOS'
and SEGMENT_TYPE='INDEX'
and TABLESPACE_NAME = 'USERS'
group by owner
,segment_name
/


2.2.- Size total indexes



select sum(bytes)/1024/1024 as "SIZE in MB"
from dba_segments
where owner='MPOS'
and SEGMENT_TYPE='INDEX'
and TABLESPACE_NAME = 'USERS'
group by 1
/


