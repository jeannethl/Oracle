Eliminar indices

vi salida_drop_indexes.sql

spool salida_drop_indexes.lst
set time on timi on

SET SERVEROUTPUT ON
DECLARE v_sentence    VARCHAR2(500);
BEGIN
FOR t IN (SELECT OWNER, INDEX_NAME FROM DBA_INDEXES WHERE OWNER = 'TX')
  LOOP
    BEGIN
      v_sentence := 'DROP INDEX ' || t.OWNER || '.' || t.INDEX_NAME;
      DBMS_OUTPUT.PUT_LINE(v_sentence);
    EXCEPTION WHEN OTHERS THEN
      NULL;
    END;
  END LOOP;
END;
/
 spool off



Eliminar constraints


vi salida_drop_constraints.sql

spool salida_drop_constraints.lst

set time on timi on

SET SERVEROUTPUT ON
DECLARE 
    v_sentence VARCHAR2(500);
BEGIN
FOR t IN (SELECT OWNER, CONSTRAINT_NAME, TABLE_NAME FROM DBA_CONSTRAINTS WHERE OWNER = 'TX')
	LOOP
	    BEGIN
	        v_sentence := 'ALTER TABLE ' || t.OWNER || '.' || t.TABLE_NAME || ' DROP CONSTRAINT ' || t.CONSTRAINT_NAME;
	        DBMS_OUTPUT.PUT_LINE(v_sentence);
	    EXCEPTION WHEN OTHERS THEN
	        NULL;  -- Ignorar cualquier error
	    END;
	END LOOP;
END;
/

spool off




