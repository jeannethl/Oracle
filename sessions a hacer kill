ALTER SESSION SET NLS_DATE_FORMAT='DD-MON-RRRR HH24:MI:SS';
SET LINESIZE 240
COL MESSAGE FORMAT A80
COL OPNAME FORMAT A30
COL START_TIME FORMAT A20
COL TARGET_DESC FORMAT A10
COL ELAPSED_SECONDS FORMAT 99999
select START_TIME
, SID
, OPNAME
, MESSAGE
, LAST_UPDATE_TIME
, SQL_ID
, TARGET_DESC
, ELAPSED_SECONDS
from gv$session_longops
where TRUNC(START_TIME)=TRUNC(SYSDATE)
--and opname like 'RMAN%'
--and TARGET_DESC='backup'
AND SID IN (9278, 5604)
ORDER BY 7;


​
SELECT PROGRAM, SQL_ID, SID, SERIAL#, STATE, STATUS, USERNAME  FROM GV$SESSION WHERE SID=9278 AND SERIAL#=20616;
SELECT PROGRAM, SQL_ID, SID, SERIAL#, STATE, STATUS, USERNAME  FROM GV$SESSION WHERE SID=5604 AND SERIAL#=6834;




alter system kill session '9278,20616' immediate;
alter system kill session '5604,6834' immediate;