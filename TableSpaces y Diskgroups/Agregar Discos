for i in $(cat data_discos.txt) ; do lsblk -fm |grep $i |grep -v none | sort -u -k 3 | awk '{print$1,$3,$4}' >> cruceDformer.txt; done
for i in $(cat data_discos.txt) ; do lsblk -fm |grep $i |grep -v none | sort -u -k 3 | awk '{print$1,$3}' >> cruceDformer.txt; done
