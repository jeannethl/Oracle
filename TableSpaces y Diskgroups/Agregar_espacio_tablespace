-- AUTOEXTEND PARA TODOS

SET SERVEROUTPUT ON
DECLARE
l_sql varchar2(2000);

cursor dataf is
SELECT FILE_NAME 
FROM DBA_DATA_FILES
WHERE AUTOEXTENSIBLE = 'NO'
AND TABLESPACE_NAME = 'DATA_MOVEMENT' 
AND BYTES/1024/1024 < 32767;

rows dataf%ROWTYPE;
BEGIN
  OPEN dataf;
  LOOP --- Bucle 
    FETCH dataf INTO rows; -- introduce/almacena data 
    EXIT WHEN dataf%NOTFOUND;
      l_sql := 'ALTER DATABASE DATAFILE '''|| rows.file_name||''' AUTOEXTEND ON NEXT 2G MAXSIZE 32767M';
      DBMS_OUTPUT.put_line(l_sql);
      BEGIN
        EXECUTE IMMEDIATE l_sql; -- ejecuta el sql
        EXCEPTION -- errores
          WHEN OTHERS THEN
          dbms_output.put_line('DATAFILE: '||rows.file_name);
          dbms_output.put_line('SQLCODE:  '||sqlcode);
          dbms_output.put_line('SQLERRM:  '||sqlerrm);
      END;
  END LOOP;
  CLOSE dataf;
END;
/



